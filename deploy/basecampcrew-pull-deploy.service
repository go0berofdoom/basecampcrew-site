[Unit]
Description=Pull and deploy the BaseCamp static site
Wants=network-online.target
After=network-online.target nginx.service

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/basecampcrew-pull-deploy
User=root
Group=root
Nice=10
ProtectSystem=strict
ReadWritePaths=/opt/basecampcrew-site /var/www/basecampcrew /var/www /run/lock
PrivateTmp=true
NoNewPrivileges=true

